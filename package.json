{
  "name": "snapchat-memories-importer",
  "version": "0.1.0",
  "description": "A desktop app that merges Snapchat export metadata into media files and exports to ZIP, Apple Photos, or Google Photos.",
  "main": "src/main.js",
  "author": "Akshat Shah",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "start": "electron .",
    "qa": "node tests/qa-importer.js",
    "dist": "node scripts/build-mac-dmg.js",
    "dist:mac": "node scripts/build-mac-dmg.js",
    "dist:win": "electron-builder --win nsis --x64 --publish never",
    "install:mac": "bash scripts/install-local-mac.sh",
    "update:mac": "npm run dist:mac && npm run install:mac",
    "pack": "electron-builder --mac dir --publish never",
    "pack:win": "electron-builder --win dir --x64 --publish never"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "exiftool-vendored": "^35.20.0",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.3.0",
    "google-auth-library": "^10.5.0",
    "mime-types": "^3.0.1"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.akshat.snapchatgooglephotosimporter",
    "productName": "Snapchat Memories Importer",
    "mac": {
      "category": "public.app-category.photography",
      "identity": null,
      "x64ArchFiles": "Contents/Resources/app.asar.unpacked/node_modules/ffmpeg-static/ffmpeg",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "Snapchat-Memories-Importer-${version}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Snapchat-Memories-Importer-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "afterPack": "scripts/after-pack.js",
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  }
}
